{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Elder Council definition",
  "description": "Schema for a council definition (councils/*.yaml). Councils are pure data; the renderer and engine consume them generically.",
  "type": "object",
  "required": ["id", "name", "purpose", "mode", "roles", "decision_outcomes", "fail_closed", "output"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string" },
    "purpose": { "type": "string" },
    "description": { "type": "string" },
    "mode": { "type": "string", "enum": ["advisory", "action-gate"] },
    "schedule": { "type": ["string", "null"], "description": "Optional cron (e.g. a scheduled compliance audit)." },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "lens", "role_key"],
        "properties": {
          "name": { "type": "string" },
          "lens": { "type": "string" },
          "role_key": { "type": "string" },
          "variant": { "type": "string", "enum": ["frontier", "open", "local"] },
          "arbitrator": { "type": "boolean" },
          "is_tool": { "type": "boolean" }
        }
      }
    },
    "decision_outcomes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "fail_closed": { "type": "string" },
    "triggers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["condition"],
        "properties": {
          "condition": { "type": "string" },
          "min_risk_score": { "type": "integer", "minimum": 1, "maximum": 25 }
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "format": { "type": "string", "enum": ["json", "madr", "markdown"] }
      }
    }
  }
}
